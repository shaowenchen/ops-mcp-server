# Copy to `.env` and adjust. The server loads `.env` from the process working directory on startup.
# Reference: configs/config.yaml and README "Configuration".

# --- HTTP MCP (local dev; avoid port 80 without root) ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=sse
SERVER_URI=/mcp
# Optional: require Authorization: Bearer <token> on MCP routes
# SERVER_TOKEN=

LOG_LEVEL=info

# --- Modules (true / false). All false = empty tool list but server runs. ---
SOPS_ENABLED=false
EVENTS_ENABLED=false
METRICS_ENABLED=false
LOGS_ENABLED=false
TRACES_ENABLED=false

# --- Backends (uncomment when enabling the matching module) ---
# SOPS_OPS_ENDPOINT=https://ops-server.example.com
# SOPS_OPS_TOKEN=

# EVENTS_OPS_ENDPOINT=https://ops-server.example.com
# EVENTS_OPS_TOKEN=

# METRICS_PROMETHEUS_ENDPOINT=https://prometheus.example.com
# METRICS_PROMETHEUS_USERNAME=
# METRICS_PROMETHEUS_PASSWORD=
# METRICS_PROMETHEUS_TOKEN=
# METRICS_PROMETHEUS_TIMEOUT=30

# LOGS_ELASTICSEARCH_ENDPOINT=https://elasticsearch.example.com
# LOGS_ELASTICSEARCH_USERNAME=
# LOGS_ELASTICSEARCH_PASSWORD=
# LOGS_ELASTICSEARCH_API_KEY=

# TRACES_JAEGER_ENDPOINT=https://jaeger.example.com
# TRACES_JAEGER_TIMEOUT=120
